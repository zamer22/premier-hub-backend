# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development            # "development" | "production"

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción solo se permite el origen definido en CORS_ORIGIN.
# En desarrollo se usa DEV_CORS_ORIGIN (por defecto http://localhost:5173).
CORS_ORIGIN=https://app.tudominio.com
DEV_CORS_ORIGIN=http://localhost:5173

# ── Cookies ───────────────────────────────────────────────────────────────────
# Clave para firmar las cookies de sesión. Usa un valor largo y aleatorio.
COOKIE_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://supabase.tudominio.com
SUPABASE_SERVICE_KEY=           # Service role key (nunca exponer al cliente)

# ── API-Football ──────────────────────────────────────────────────────────────
APIFOOTBALL_KEY=                # API key de api-sports.io
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io
APIFOOTBALL_LEAGUE_ID=39        # 39 = Premier League
APIFOOTBALL_SEASON=2025

# ── News API ──────────────────────────────────────────────────────────────────
NEWS_API_KEY=                   # API key de newsapi.org
NEWS_BASE_URL=https://newsapi.org/v2
NEWS_CACHE_TTL_MINUTES=30       # Tiempo de vida del cache de noticias (minutos)

# ── Partido en vivo ───────────────────────────────────────────────────────────
# ID del fixture activo para auto-sync en tiempo real. Dejar vacío si no hay partido.
LIVE_FIXTURE_ID=
